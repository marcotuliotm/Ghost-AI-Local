{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "composite": true,
    "skipLibCheck": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "./dist-electron/types",
    "outDir": "dist-electron",
    "strict": true
  },
  "include": ["electron", "vite.config.mts"]
}
